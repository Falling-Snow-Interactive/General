.range_root {
    flex-grow: 1;
    flex-shrink: 0;
    flex-direction: row;
}

.range_label {
    width: 40%;
    margin-left: 2px;
    -unity-text-align: lower-left;
}

.range_field {
    flex-grow: 1;
    flex-shrink: 0;
    flex-direction: row;
}

.range_field_label {
    flex-grow: 0;
    flex-shrink: 0;
    -unity-text-align: lower-left;
}

.range_field_value {
    flex-grow: 1;
    flex-shrink: 0;
}

.range_field_space{
    width: 5px;
}